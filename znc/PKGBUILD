pkgname=znc
pkgver=1.8.1
pkgrel=1
pkgdesc='An IRC bouncer with modules & scripts support'
url='https://wiki.znc.in/'
license=('GPL2')
arch=('x86_64')
depends=('libsasl' 'icu' 'boost-libs')
makedepends=('tcl' 'python' 'perl' 'cmake' 'boost')
optdepends=('tcl: modtcl module'
            'python: modpython module'
            'perl: modperl module'
            'cyrus-sasl: saslauth module')
install=$pkgname.install
source=("https://znc.in/releases/archive/$pkgname-$pkgver.tar.gz"{,.sig}
        "$pkgname.tmpfiles"
        "$pkgname.sysusers")
validpgpkeys=('D5823CACB477191CAC0075555AE420CC0209989E') #Alexey Sokolov <alexey@asokolov.org>
sha256sums=('3195f7614a800a843af12271593d39cd3eb40c15657cce56d9cf28754cd86141'
            'SKIP'
            '25fb46328d1c2f017649adb0e5408544ca069ca0613059f3d0ede96728a019be'
            'e564a372fa889b7516f22fd5bbd5fb00e6a8b137e4e5af657d9670cbdd01f0f9')

prepare() {
  mkdir -p build
}

build() {
  cd build
  cmake ../$pkgname-$pkgver \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DWANT_PYTHON=ON \
    -DWANT_PERL=ON \
    -DWANT_TCL=ON \
    -DWANT_SYSTEMD=ON \
    -DSYSTEMD_DIR=/usr/lib/systemd/system
  make
}

package() {
  cd build
  make DESTDIR="$pkgdir" install
  install -Dm644 "$srcdir/$pkgname.sysusers" "$pkgdir/usr/lib/sysusers.d/$pkgname.conf"
  install -Dm644 "$srcdir/$pkgname.tmpfiles" "$pkgdir/usr/lib/tmpfiles.d/$pkgname.conf"
}
