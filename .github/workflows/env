#!/bin/bash

if [[ ${no_changes+x} ]]; then
    exit 0
fi

pacman -Syu --noconfirm wget

cd "$PACKAGE"

cp * /home/build

chown -R build:build /home/build

# Work-around the issue with glibc 2.33 on old Docker engines
# Extract files directly as pacman is also affected by the issue
# See https://github.com/lxqt/lxqt-panel/pull/1562
#patched_glibc=glibc-linux4-2.33-4-x86_64.pkg.tar.zst
#curl -LO https://repo.archlinuxcn.org/x86_64/$patched_glibc
#bsdtar -C / -xvf $patched_glibc
#rm $patched_glibc

wget https://raw.githubusercontent.com/ungoogled-software/ungoogled-chromium-archlinux/master/.github/workflows/build/makepkg.conf
mv makepkg.conf /etc/makepkg.conf
